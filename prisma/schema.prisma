generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== Auth 模块 ====================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  role         String   @default("patient")
  createdAt    DateTime @default(now())

  patientProfiles PatientProfile[]
  registrations   Registration[]

  @@index([email])
  @@index([phone])
  @@schema("auth")
}

model PatientProfile {
  id     String @id @default(cuid())
  userId String
  name   String
  idCard String
  phone  String
  gender String

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@index([userId])
  @@schema("auth")
}

// ==================== Hospital 模块 ====================

model Hospital {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  level       String
  phone       String
  description String   @default("")
  imageUrl    String   @default("")
  createdAt   DateTime @default(now())

  departments Department[]
  doctors     Doctor[]

  @@index([city])
  @@index([level])
  @@schema("hospital")
}

model Department {
  id          String @id @default(cuid())
  name        String
  description String @default("")
  hospitalId  String

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctors  Doctor[]

  @@unique([name, hospitalId])
  @@index([hospitalId])
  @@schema("hospital")
}

model Doctor {
  id           String @id @default(cuid())
  name         String
  title        String
  specialty    String
  introduction String @default("")
  avatarUrl    String @default("")
  departmentId String
  hospitalId   String

  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  hospital      Hospital       @relation(fields: [hospitalId], references: [id])
  schedules     Schedule[]
  registrations Registration[]

  @@index([departmentId])
  @@index([hospitalId])
  @@index([name])
  @@schema("hospital")
}

model Schedule {
  id          String   @id @default(cuid())
  doctorId    String
  date        String
  timeSlot    String
  quota       Int
  bookedCount Int      @default(0)
  type        String   @default("normal")
  createdAt   DateTime @default(now())

  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@unique([doctorId, date, timeSlot, type])
  @@index([doctorId, date])
  @@index([date])
  @@schema("hospital")
}

// ==================== Registration 模块 ====================

model Registration {
  id         String   @id @default(cuid())
  patientId  String
  profileId  String
  doctorId   String
  scheduleId String
  date       String
  timeSlot   String
  type       String
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  patient  User           @relation(fields: [patientId], references: [id])
  profile  PatientProfile @relation(fields: [profileId], references: [id])
  doctor   Doctor         @relation(fields: [doctorId], references: [id])
  schedule Schedule       @relation(fields: [scheduleId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduleId])
  @@index([date])
  @@index([patientId, date, timeSlot])
  @@schema("registration")
}

// ==================== Chat/AI 模块 ====================

/// 消息反馈表
model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  rating    String   // "helpful" | "not_helpful"
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@schema("chat")
}

/// 用户记忆表（偏好、历史摘要）
model UserMemory {
  id        String   @id @default(cuid())
  userId    String   @unique
  preferences String  @default("{}")
  summary   String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@schema("chat")
}

/// 会话表
model Conversation {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  title     String   @default("新对话")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([sessionId])
  @@index([userId])
  @@index([updatedAt])
  @@schema("chat")
}

/// 工具调用记录表
model ToolCall {
  id        String   @id @default(cuid())
  messageId String
  sequence  Int
  toolName  String
  arguments String   /// JSON
  result    String?
  status    String   @default("pending") /// pending | success | error
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@schema("chat")
}

/// 消息表
model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String?
  /// DeepSeek 推理模式的思考过程文本
  reasoningContent String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    ToolCall[]

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@schema("chat")
}

/// 会话状态表
model SessionState {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  userId         String?
  step           String   @default("idle")
  cache          String   @default("{}")
  contextSummary String   @default("")
  updatedAt      DateTime @updatedAt

  @@index([sessionId])
  @@schema("chat")
}
